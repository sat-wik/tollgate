{
  "name": "tollgate",
  "version": "0.1.0",
  "description": "A local, provider-agnostic LLM proxy that estimates the cost of requests, lints prompts for waste, and gives you a personal spend dashboard.",
  "type": "module",
  "bin": {
    "tollgate": "./dist/src/index.js"
  },
  "files": [
    "dist",
    "config"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "tsx src/index.ts",
    "init": "tsx src/index.ts init",
    "build": "tsc -p tsconfig.build.json && node scripts/copy-assets.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "better-sqlite3": "^11.8.1",
    "fastify": "^5.2.1",
    "tiktoken": "^1.0.22"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
